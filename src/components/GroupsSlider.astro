---
import { worldCupGroups } from '@/data/site';
import { selecoes } from '@/data/selecoes';

const LOGO_BASE = '/logos/copa2026';
---

<section class="groups-slider border-y border-ixporte-red/40 bg-ixporte-black" aria-label="Grupos da Copa do Mundo 2026">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
    <h2 class="font-headline font-bold text-ixporte-red text-sm sm:text-base uppercase tracking-[0.15em] text-center mb-4">
      Copa do Mundo 2026 · Grupos
    </h2>

    <div class="relative flex items-center gap-2 sm:gap-4 max-h-[300px]">
      <!-- Prev -->
      <button
        type="button"
        id="groups-prev"
        class="flex-shrink-0 w-8 h-8 sm:w-10 sm:h-10 flex items-center justify-center text-ixporte-red hover:text-ixporte-white transition-colors duration-200"
        aria-label="Grupo anterior"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
      </button>

      <!-- Slider -->
      <div
        id="groups-track"
        class="groups-track flex-1 flex overflow-x-auto scroll-smooth snap-x snap-mandatory gap-0 scrollbar-hide"
        style="scroll-behavior: smooth;"
      >
        {
          worldCupGroups.map((group) => (
            <div
              class="groups-slide flex-shrink-0 w-full min-w-[260px] snap-start flex flex-col items-center justify-center py-3"
              data-group={group.id}
            >
              <p class="group-name font-headline text-ixporte-red/80 text-[14px] uppercase tracking-widest mb-3">
                {group.label}
              </p>
              <div class="flags-row flex items-end justify-center gap-1 sm:gap-[18px]">
               {group.teams.map((team) => (
  <div
    class="flex flex-col items-center gap-1 sm:gap-2 min-w-[60px] sm:min-w-[112px] cursor-pointer group/flag"
    onclick={`openSliderModal('${team.name}')`}
  >
    <div class="flag-circle flex h-[60px] w-[60px] sm:h-[112px] sm:w-[112px] items-center justify-center">
      <img
        src={`${LOGO_BASE}/${team.logo}`}
        alt={`Logo ${team.name}`}
        class="h-[60px] w-[60px] sm:h-[112px] sm:w-[112px] object-contain transition-transform duration-200 group-hover/flag:scale-110"
        loading="lazy"
        width="112"
        height="112"
      />
    </div>
    <span class="flag-name text-[9px] sm:text-[11px] text-ixporte-white text-center leading-tight max-w-[56px] sm:max-w-[80px]">
      {team.name}
    </span>
  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>

      <!-- Next -->
      <button
        type="button"
        id="groups-next"
        class="flex-shrink-0 w-8 h-8 sm:w-10 sm:h-10 flex items-center justify-center text-ixporte-red hover:text-ixporte-white transition-colors duration-200"
        aria-label="Próximo grupo"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </button>
    </div>

    <!-- Indicators -->
    <div id="groups-indicators" class="flex justify-center gap-1.5 mt-4" role="tablist" aria-label="Indicadores de grupo">
      {
        worldCupGroups.map((group, i) => (
          <button
            type="button"
            class="groups-indicator h-0.5 w-4 sm:w-5 bg-ixporte-red/25 transition-all duration-300 rounded-full"
            data-index={i}
            role="tab"
            aria-label={`Grupo ${group.id}`}
            aria-selected={i === 0 ? 'true' : 'false'}
          />
        ))
      }
    </div>
  </div>
</section>

<!-- Modal do Slider -->
<div
  id="slider-modal-overlay"
  class="fixed inset-0 z-[100] bg-black/85 hidden items-center justify-center p-4"
  onclick="closeSliderModal(event)"
>
  <div
    id="slider-modal-box"
    class="relative w-full max-w-lg bg-[#111] border border-ixporte-red/30 overflow-hidden max-h-[90vh] overflow-y-auto"
  >
    <div class="relative h-[200px] bg-[#1a1a1a] flex items-end">
      <div class="absolute inset-0 flex items-center justify-center">
        <img id="slider-modal-logo" src="" alt="" class="w-24 h-24 object-contain opacity-30" />
      </div>
      <div class="absolute inset-0 bg-gradient-to-t from-[#111] via-[#111]/60 to-transparent"></div>
      <div class="relative z-10 p-6">
        <span id="slider-modal-grupo" class="text-ixporte-red text-[10px] tracking-[3px] uppercase mb-1 block"></span>
        <h3 id="slider-modal-name" class="font-headline font-bold text-3xl text-ixporte-white uppercase"></h3>
      </div>
    </div>
    <button
      onclick="closeSliderModalDirect()"
      class="absolute top-3 right-3 z-20 text-ixporte-red hover:text-white transition-colors text-2xl leading-none w-8 h-8 flex items-center justify-center"
      aria-label="Fechar"
    >✕</button>
    <div class="p-6 space-y-4">
      <div class="grid grid-cols-2 gap-3">
        <div class="bg-white/5 p-3">
          <p class="text-ixporte-red text-[9px] tracking-widest uppercase mb-1">Técnico</p>
          <p id="slider-modal-tecnico" class="text-ixporte-white text-sm font-medium"></p>
        </div>
        <div class="bg-white/5 p-3">
          <p class="text-ixporte-red text-[9px] tracking-widest uppercase mb-1">1ª Copa</p>
          <p id="slider-modal-primeira" class="text-ixporte-white text-sm font-medium"></p>
        </div>
        <div class="bg-white/5 p-3">
          <p class="text-ixporte-red text-[9px] tracking-widest uppercase mb-1">Melhor resultado</p>
          <p id="slider-modal-melhor" class="text-ixporte-white text-sm font-medium"></p>
        </div>
        <div class="bg-white/5 p-3">
          <p class="text-ixporte-red text-[9px] tracking-widest uppercase mb-1">Maior artilheiro</p>
          <p id="slider-modal-artilheiro" class="text-ixporte-white text-sm font-medium"></p>
        </div>
      </div>
      <div class="bg-white/5 p-3">
        <p class="text-ixporte-red text-[9px] tracking-widest uppercase mb-1">Eliminatórias</p>
        <p id="slider-modal-elim" class="text-ixporte-white text-sm"></p>
      </div>
      <div class="bg-ixporte-red/10 border border-ixporte-red/20 p-3">
        <p class="text-ixporte-red text-[9px] tracking-widest uppercase mb-1">Curiosidade</p>
        <p id="slider-modal-curiosidade" class="text-ixporte-white/80 text-sm leading-relaxed"></p>
      </div>
      <div id="slider-modal-conv-wrap" class="bg-white/5 p-3">
        <p class="text-ixporte-red text-[9px] tracking-widest uppercase mb-1">Convocação</p>
        <p id="slider-modal-convocacao" class="text-ixporte-white/70 text-xs leading-relaxed"></p>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ selecoes }}>
  function openSliderModal(name) {
    const s = selecoes.find(x => x.name === name);
    if (!s) return;

    document.getElementById('slider-modal-name').textContent = s.name;
    document.getElementById('slider-modal-grupo').textContent = `Grupo ${s.grupo}`;
    document.getElementById('slider-modal-tecnico').textContent = s.tecnico;
    document.getElementById('slider-modal-primeira').textContent = s.primeira;
    document.getElementById('slider-modal-melhor').textContent = s.melhor;
    document.getElementById('slider-modal-artilheiro').textContent = s.artilheiro;
    document.getElementById('slider-modal-elim').textContent = s.eliminatorias;
    document.getElementById('slider-modal-curiosidade').textContent = s.curiosidade;

    const logoEl = document.getElementById('slider-modal-logo');
    logoEl.src = `/logos/copa2026/${s.logo}`;
    logoEl.alt = s.name;

    const convWrap = document.getElementById('slider-modal-conv-wrap');
    const convEl = document.getElementById('slider-modal-convocacao');
    if (s.convocacao) {
      convEl.textContent = s.convocacao;
      convWrap.style.display = 'block';
    } else {
      convWrap.style.display = 'none';
    }

    const overlay = document.getElementById('slider-modal-overlay');
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeSliderModalDirect() {
    const overlay = document.getElementById('slider-modal-overlay');
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    document.body.style.overflow = '';
  }

  function closeSliderModal(e) {
    if (e.target === document.getElementById('slider-modal-overlay')) closeSliderModalDirect();
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSliderModalDirect();
  });

  window.openSliderModal = openSliderModal;
  window.closeSliderModal = closeSliderModal;
  window.closeSliderModalDirect = closeSliderModalDirect;
</script>

<style>
  .groups-track {
    -ms-overflow-style: none;
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
  }

  .groups-track::-webkit-scrollbar {
    display: none;
  }

  .groups-slide {
    scroll-snap-align: start;
  }

  .flag-circle img {
    object-fit: contain;
    filter: drop-shadow(0 0 6px rgba(255,255,255,0.22));
    transition: filter 200ms ease;
  }

  @media (min-width: 640px) {
    .flag-circle img {
      width: 112px;
      height: 112px;
    }
  }

  .group\/flag:hover .flag-circle img {
    filter: drop-shadow(0 0 12px rgba(255,255,255,0.45));
  }

  .groups-indicator.active {
    background-color: #FF0000;
    width: 1.75rem;
  }

  @media (min-width: 640px) {
    .groups-indicator.active {
      width: 2.25rem;
    }
  }
</style>

<script>
  function initGroupsSlider() {
    const track = document.getElementById('groups-track');
    const prevBtn = document.getElementById('groups-prev');
    const nextBtn = document.getElementById('groups-next');
    const indicators = document.querySelectorAll<HTMLButtonElement>('.groups-indicator');
    const slides = document.querySelectorAll('.groups-slide');

    if (!track || slides.length === 0) return;

    let currentIndex = 0;

    function getSlideWidth() {
      return track!.clientWidth;
    }

    function scrollToIndex(index: number) {
      currentIndex = Math.max(0, Math.min(index, slides.length - 1));
      track!.scrollTo({
        left: currentIndex * getSlideWidth(),
        behavior: 'smooth',
      });
      updateIndicators();
    }

    function updateIndicators() {
      indicators.forEach((indicator, i) => {
        const isActive = i === currentIndex;
        indicator.classList.toggle('active', isActive);
        indicator.setAttribute('aria-selected', String(isActive));
      });
    }

    function getCurrentIndexFromScroll() {
      const slideWidth = getSlideWidth();
      if (slideWidth === 0) return 0;
      return Math.round(track!.scrollLeft / slideWidth);
    }

    prevBtn?.addEventListener('click', () => scrollToIndex((currentIndex - 1 + slides.length) % slides.length));
    nextBtn?.addEventListener('click', () => scrollToIndex((currentIndex + 1) % slides.length));

    indicators.forEach((indicator) => {
      indicator.addEventListener('click', () => {
        const index = parseInt(indicator.dataset.index ?? '0', 10);
        scrollToIndex(index);
      });
    });

    track.addEventListener('scroll', () => {
      const newIndex = getCurrentIndexFromScroll();
      if (newIndex !== currentIndex) {
        currentIndex = newIndex;
        updateIndicators();
      }
    }, { passive: true });

    window.addEventListener('resize', () => {
      scrollToIndex(currentIndex);
    });

    updateIndicators();
  }

  initGroupsSlider();
  document.addEventListener('astro:page-load', initGroupsSlider);
</script>
