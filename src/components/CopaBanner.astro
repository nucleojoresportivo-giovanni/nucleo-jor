---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<section class:list={['relative overflow-hidden', compact ? 'my-8' : 'my-12 lg:my-16']}>
  <a
    href="/copa-feminina-2027"
    class="group block relative bg-nucleo-gold overflow-hidden card-hover"
  >
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[repeating-linear-gradient(45deg,transparent,transparent_10px,rgba(0,0,0,0.1)_10px,rgba(0,0,0,0.1)_20px)]"></div>
    </div>

    <div class:list={['relative px-6 sm:px-10 lg:px-16', compact ? 'py-8' : 'py-12 lg:py-16']}>
      <div class="max-w-4xl">
        <span class="inline-block text-nucleo-black/60 text-xs uppercase tracking-[0.2em] font-medium mb-3">
          Seção Especial
        </span>
        <h2 class="font-headline font-bold text-nucleo-black text-2xl sm:text-3xl lg:text-4xl uppercase tracking-wide leading-tight group-hover:opacity-90 transition-opacity duration-200">
          Copa do Mundo Feminina 2027
        </h2>
        <p class="mt-3 font-editorial italic text-nucleo-black/70 text-base sm:text-lg max-w-2xl">
          O Brasil sediará o maior evento esportivo feminino do planeta. Acompanhe a cobertura completa do Núcleo.
        </p>
        <span class="mt-5 inline-flex items-center gap-2 text-nucleo-black font-medium text-sm uppercase tracking-wider group-hover:gap-3 transition-all duration-200">
          Ver cobertura
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </span>
      </div>
    </div>
  </a>
</section>
