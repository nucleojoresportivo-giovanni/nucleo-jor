---
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  title: string;
  excerpt: string;
  category: string;
  coverImage: string;
  href: string;
  date: Date;
  size?: 'lg' | 'md' | 'sm';
}

const { title, excerpt, category, coverImage, href, date, size = 'md' } = Astro.props;

const formattedDate = date.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});

const sizeClasses = {
  lg: {
    wrapper: 'col-span-1 md:col-span-2 md:row-span-2',
    image: 'aspect-[16/9] md:aspect-auto md:h-full md:min-h-[280px]',
    title: 'text-xl sm:text-2xl lg:text-3xl',
    showExcerpt: true,
  },
  md: {
    wrapper: 'col-span-1',
    image: 'aspect-[16/10]',
    title: 'text-lg sm:text-xl',
    showExcerpt: true,
  },
  sm: {
    wrapper: 'col-span-1',
    image: 'aspect-[16/10]',
    title: 'text-base sm:text-lg',
    showExcerpt: false,
  },
};

const config = sizeClasses[size];
---

<article class:list={['group card-hover', config.wrapper]}>
  <a href={href} class="block h-full bg-ixporte-black border border-ixporte-purple/15 overflow-hidden transition-colors duration-300 hover:border-ixporte-crimson/40">
    <div class:list={['relative overflow-hidden', config.image]}>
      <img
        src={coverImage}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
      <!-- Overlay com gradiente de identidade -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-[#2A0048]/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
    </div>
    <div class="p-4 sm:p-5">
      <CategoryBadge category={category} />
      <h2 class:list={['mt-2 font-headline font-black tracking-tight text-ixporte-white leading-snug transition-colors duration-200 group-hover:text-gradient', config.title]}>
        {title}
      </h2>
      {config.showExcerpt && (
        <p class="mt-2 text-sm text-ixporte-white/50 line-clamp-2 font-body">{excerpt}</p>
      )}
      <time datetime={date.toISOString()} class="mt-3 block text-xs text-ixporte-white/30 uppercase tracking-wider">
        {formattedDate}
      </time>
    </div>
  </a>
</article>
