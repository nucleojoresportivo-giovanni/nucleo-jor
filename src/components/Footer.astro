---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-ixporte-red/20 bg-ixporte-black mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="inline-block">
          <img
            src="/logo-nucleo.svg"
            alt="ixporte — Jornalismo Esportivo"
            class="h-8 w-auto"
            width="160"
            height="32"
          />
        </a>
        <p class="mt-3 text-sm text-ixporte-white/60 leading-relaxed max-w-xs">
          Portal de jornalismo esportivo produzido por estudantes do curso de Jornalismo da UFSC.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-headline text-ixporte-red uppercase tracking-wider text-sm mb-4">Navegação</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/reportagens" class="text-ixporte-white/60 hover:text-ixporte-red transition-colors duration-200">Reportagens</a></li>
          <li><a href="/copa-feminina-2027" class="text-ixporte-white/60 hover:text-ixporte-red transition-colors duration-200">Copa Feminina 2027</a></li>
          <li><a href="/especiais" class="text-ixporte-white/60 hover:text-ixporte-red transition-colors duration-200">Especiais</a></li>
          <li><a href="/sobre" class="text-ixporte-white/60 hover:text-ixporte-red transition-colors duration-200">Sobre</a></li>
          <li><a href="/contato" class="text-ixporte-white/60 hover:text-ixporte-red transition-colors duration-200">Contato</a></li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h3 class="font-headline text-ixporte-red uppercase tracking-wider text-sm mb-4">Redes Sociais</h3>
        <div class="flex gap-4">
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="text-ixporte-white/60 hover:text-ixporte-red transition-colors duration-200" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="text-ixporte-white/60 hover:text-ixporte-red transition-colors duration-200" aria-label="Twitter/X">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://youtube.com" target="_blank" rel="noopener noreferrer" class="text-ixporte-white/60 hover:text-ixporte-red transition-colors duration-200" aria-label="YouTube">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
        <p class="mt-4 text-xs text-ixporte-white/40">
          Parceria com <a href="https://radio.ufsc.br" target="_blank" rel="noopener noreferrer" class="text-ixporte-red hover:underline">Rádio UFSC</a>
        </p>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-ixporte-red/10 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-ixporte-white/40">
      <p>&copy; {currentYear} ixporte — Jornalismo Esportivo. Todos os direitos reservados.</p>
      <p>Universidade Federal de Santa Catarina</p>
    </div>
  </div>
</footer>
