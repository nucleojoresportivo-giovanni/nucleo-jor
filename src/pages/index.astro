  { name: 'Haiti', grupo: 'C', logo: 'haiti.png', tecnico: 'Sébastien Migné', primeira: '1974', melhor: 'Fase de grupos (1974)', artilheiro: 'Duckens Nazon (44 gols)', eliminatorias: 'V:3 E:2 D:1 GM:9 GS:6', curiosidade: 'Garantiu a vaga sem jogar nenhuma partida em casa.', convocacao: 'GR: Johnny Placide · DEF: Carlens Arcus, JK Duverne · MEI: Jeanricner Bellegarde · ATA: Wilson Isidor, Duckens Nazon' },
  { name: 'EUA', grupo: 'D', logo: 'usa.png', tecnico: 'Mauricio Pochettino', primeira: '1930', melhor: '3º lugar (1930)', artilheiro: 'Clint Dempsey (57 gols)', eliminatorias: 'V:— E:— D:— GM:— GS:—', curiosidade: 'Em 1950, venceram a Inglaterra por 1×0 — "O Milagre na Grama".', convocacao: '' },
  { name: 'Austrália', grupo: 'D', logo: 'australia.png', tecnico: 'Tony Popovic', primeira: '1974', melhor: 'Oitavas (2006)', artilheiro: 'Tim Cahill (50 gols)', eliminatorias: 'V:11 E:4 D:1 GM:38 GS:7', curiosidade: 'Aplicou a maior goleada da história: 31×0 contra a Samoa Americana.', convocacao: '' },
  { name: 'Paraguai', grupo: 'D', logo: 'paraguai.png', tecnico: 'Gustavo Alfaro', primeira: '1930', melhor: 'Quartas (2010)', artilheiro: 'Roque Santa Cruz (32 gols)', eliminatorias: 'V:7 E:7 D:4 GM:14 GS:10', curiosidade: 'Conhecida como La Albirroja, referência em organização defensiva.', convocacao: '' },
  { name: 'Turquia', grupo: 'D', logo: 'turquia.png', tecnico: 'Vincenzo Montella', primeira: '1954', melhor: '3º lugar (2002)', artilheiro: 'Hakan Şükür (51 gols)', eliminatorias: 'V:4 E:1 D:1 GM:17 GS:12', curiosidade: 'Detém o recorde do gol mais rápido — Hakan Şükür em 11 segundos em 2002.', convocacao: '' },
  { name: 'Alemanha', grupo: 'E', logo: 'alemanha.png', tecnico: 'Julian Nagelsmann', primeira: '1934', melhor: 'Campeã (4x)', artilheiro: 'Miroslav Klose (71 gols)', eliminatorias: 'V:5 E:0 D:1 GM:16 GS:3', curiosidade: 'Única seleção a conquistar as Copas masculina e feminina.', convocacao: 'GR: Manuel Neuer · DEF: Antonio Rudiger, Joshua Kimmich · MEI: Jamal Musiala, Florian Wirtz · ATA: Kai Havertz' },
  { name: 'Costa do Marfim', grupo: 'E', logo: 'costa-do-marfim.png', tecnico: 'Emerse Faé', primeira: '2006', melhor: 'Fase de grupos', artilheiro: 'Didier Drogba (66 gols)', eliminatorias: 'V:8 E:2 D:0 GM:25 GS:0', curiosidade: 'Os Elefantes tiveram geração de ouro com Drogba e Yaya Touré.', convocacao: 'GR: Yahia Fofana · DEF: Ousmane Diomande, Evan Ndicka · MEI: Franck Kessié, Seko Fofana · ATA: Simon Adingra, Amad Diallo' },
  { name: 'Curaçao', grupo: 'E', logo: 'curacao.png', tecnico: 'Dick Advocaat', primeira: '2026', melhor: '1ª participação', artilheiro: 'Rangelo Janga (21 gols)', eliminatorias: 'V:7 E:3 D:0 GM:28 GS:4', curiosidade: 'Menor nação do mundo a se qualificar para uma Copa — menos de 150.000 habitantes.', convocacao: 'GR: Eloy Room · DEF: Riechedly Bazoer, Armando Obispo · MEI: Juninho Bacuna, Leandro Bacuna · ATA: Tahith Chong, Sontje Hansen' },
  { name: 'Equador', grupo: 'E', logo: 'equador.png', tecnico: 'Sebastian Beccacece', primeira: '2002', melhor: 'Oitavas (2006)', artilheiro: 'Enner Valencia (49 gols)', eliminatorias: 'V:8 E:8 D:2 GM:14 GS:5', curiosidade: 'Perdeu 3 pontos por falsificação de documentos no ciclo anterior.', convocacao: '' },
  { name: 'Holanda', grupo: 'F', logo: 'holanda.png', tecnico: 'Ronald Koeman', primeira: '1934', melhor: 'Vice-campeã (3x)', artilheiro: 'Memphis Depay (54 gols)', eliminatorias: 'V:6 E:2 D:0 GM:25 GS:2', curiosidade: 'A Laranja Mecânica criou o Futebol Total em 1974 — nunca venceu a Copa.', convocacao: '' },
  { name: 'Japão', grupo: 'F', logo: 'japao.png', tecnico: 'Hajime Moriyasu', primeira: '1998', melhor: 'Oitavas (2002)', artilheiro: 'Kunishige Kamamoto (75 gols)', eliminatorias: 'V:7 E:2 D:1 GM:30 GS:3', curiosidade: 'Primeira seleção de fora das Américas a disputar uma Copa América.', convocacao: 'GR: Zion Suzuki · DEF: Takehiro Tomiyasu, Ko Itakura · MEI: Takefusa Kubo, Daichi Kamada · ATA: Ayase Ueda' },
  { name: 'Suécia', grupo: 'F', logo: 'suecia.png', tecnico: 'Graham Potter', primeira: '1934', melhor: 'Vice-campeã (1958)', artilheiro: 'Zlatan Ibrahimović (62 gols)', eliminatorias: 'V:0 E:2 D:4 GM:4 GS:12', curiosidade: 'Classificou-se pelos play-offs após terminar em último no grupo, sem nenhuma vitória.', convocacao: 'GR: Viktor Johansson · DEF: Victor Nilsson Lindelof, Isak Hien · MEI: Lucas Bergvall · ATA: Viktor Gyökeres, Alexandre Isak' },
  { name: 'Tunísia', grupo: 'F', logo: 'tunisia.png', tecnico: 'Sabri Lamouchi', primeira: '1978', melhor: 'Fase de grupos', artilheiro: 'Issam Jemâa (36 gols)', eliminatorias: 'V:9 E:1 D:0 GM:22 GS:0', curiosidade: 'Primeira seleção africana a vencer um jogo numa Copa — 3×1 sobre o México em 1978.', convocacao: 'GR: Aymen Dahman · DEF: Dylan Bronn, Montassar Talbi · MEI: Hannibal Mejbri, Ellyes Skhiri · ATA: Elias Saad' },
  { name: 'Bélgica', grupo: 'G', logo: 'belgica.png', tecnico: 'Rudi Garcia', primeira: '1930', melhor: '3º lugar (2018)', artilheiro: 'Romelu Lukaku (89 gols)', eliminatorias: 'V:5 E:3 D:0 GM:29 GS:7', curiosidade: 'Recebeu o apelido Os Diabos Vermelhos em 1906, após vitória sobre a Holanda.', convocacao: 'GR: Thibaut Courtois · DEF: Timothy Castagne, Zeno Debast · MEI: Kevin De Bruyne, Amadou Onana · ATA: Romelu Lukaku, Jeremy Doku' },
  { name: 'Egito', grupo: 'G', logo: 'egito.png', tecnico: 'Hossam Hassan', primeira: '1934', melhor: 'Fase de grupos (1934)', artilheiro: 'Hossam Hassan (68 gols)', eliminatorias: 'V:8 E:2 D:0 GM:20 GS:2', curiosidade: 'Perdeu a Copa de 1930 porque uma tempestade adiou o barco da delegação.', convocacao: 'GR: Mohamed El Shenawy · MEI: Mohamed Salah, Mahmoud Trezeguet · ATA: Omar Marmoush' },
  { name: 'Irã', grupo: 'G', logo: 'iran.png', tecnico: 'Amir Ghalenoei', primeira: '1978', melhor: 'Fase de grupos', artilheiro: 'Ali Daei (109 gols)', eliminatorias: 'V:7 E:2 D:1 GM:19 GS:8', curiosidade: 'Ali Daei foi o maior artilheiro internacional até Cristiano Ronaldo superar sua marca.', convocacao: 'GR: Alireza Beiranvand · DEF: Ehsan Hajsafi · MEI: Alireza Jahanbakhsh, Saman Ghoddos · ATA: Mehdi Taremi' },
