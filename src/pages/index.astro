---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroCard from '@/components/HeroCard.astro';
import GroupsSlider from '@/components/GroupsSlider.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import CopaBanner from '@/components/CopaBanner.astro';
import { getCollection } from 'astro:content';

const allReportagens = await getCollection('reportagens');
const sorted = allReportagens.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const featured = sorted.find((r) => r.data.featured) ?? sorted[0];
const rest = sorted.filter((r) => r.id !== featured.id);

const gridArticles = rest.slice(0, 5);
const lg = gridArticles[0];
const md = gridArticles.slice(1, 3);
const sm = gridArticles.slice(3, 6);
---

<BaseLayout title="Home">
  <!-- Hero -->
  <HeroCard
    title={featured.data.title}
    excerpt={featured.data.excerpt}
    category={featured.data.category}
    coverImage={featured.data.coverImage}
    href={`/reportagens/${featured.slug}`}
    date={featured.data.date}
  />

  <!-- Groups Slider -->
  <GroupsSlider />

<!-- Seleções clicáveis -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-end justify-between mb-6">
    <h2 class="font-headline font-bold text-2xl text-nucleo-white uppercase tracking-wide">
      As 48 Seleções
    </h2>
    <a href="/copa-2026/selecoes" class="text-sm text-nucleo-gold uppercase tracking-wider hover:text-nucleo-white transition-colors">
      Ver todas →
    </a>
  </div>
  <div class="grid grid-cols-4 sm:grid-cols-6 lg:grid-cols-8 gap-3">
    {['mexico','africa','coreia-do-sul','tcheca','canada','bosnia','catar','suica','brasil','marrocos','escocia','haiti','usa','australia','paraguai','turquia','alemanha','costa-do-marfim','curacao','equador','holanda','japao','suecia','tunisia','belgica','egito','iran','nz','espanha','cabo-verde','arabia','uruguai','franca','iraque','noruega','senegal','argentina','argelia','austria','jordania','portugal','congo','uzbequistao','colombia','inglaterra','croacia','gana','panama'].map((logo) => {
      const nomes = {'mexico':'México','africa':'África do Sul','coreia-do-sul':'Coreia do Sul','tcheca':'Rep. Tcheca','canada':'Canadá','bosnia':'Bósnia','catar':'Catar','suica':'Suíça','brasil':'Brasil','marrocos':'Marrocos','escocia':'Escócia','haiti':'Haiti','usa':'EUA','australia':'Austrália','paraguai':'Paraguai','turquia':'Turquia','alemanha':'Alemanha','costa-do-marfim':'Costa do Marfim','curacao':'Curaçao','equador':'Equador','holanda':'Holanda','japao':'Japão','suecia':'Suécia','tunisia':'Tunísia','belgica':'Bélgica','egito':'Egito','iran':'Irã','nz':'Nova Zelândia','espanha':'Espanha','cabo-verde':'Cabo Verde','arabia':'Arábia Saudita','uruguai':'Uruguai','franca':'França','iraque':'Iraque','noruega':'Noruega','senegal':'Senegal','argentina':'Argentina','argelia':'Argélia','austria':'Áustria','jordania':'Jordânia','portugal':'Portugal','congo':'RD Congo','uzbequistao':'Uzbequistão','colombia':'Colômbia','inglaterra':'Inglaterra','croacia':'Croácia','gana':'Gana','panama':'Panamá'};
      const nome = nomes[logo];
      return (
        <button
          onclick={`openModal('${nome}')`}
          class="flex flex-col items-center gap-2 p-2 hover:bg-white/5 rounded transition-colors group"
          title={nome}
        >
          <img src={`/logos/copa2026/${logo}.png`} alt={nome} class="w-10 h-10 object-contain group-hover:scale-110 transition-transform" />
          <span class="text-nucleo-white/50 text-[9px] text-center leading-tight group-hover:text-nucleo-gold transition-colors">{nome}</span>
        </button>
      );
    })}
  </div>
</section>

  <!-- Asymmetric Grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="flex items-end justify-between mb-8">
      <h2 class="font-headline font-bold text-2xl sm:text-3xl text-nucleo-white uppercase tracking-wide">
        Últimas Reportagens
      </h2>
      <a href="/reportagens" class="text-sm text-nucleo-gold hover:text-nucleo-white transition-colors duration-200 uppercase tracking-wider">
        Ver todas →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6 auto-rows-fr">
      {lg && (
        <ArticleCard
          title={lg.data.title}
          excerpt={lg.data.excerpt}
          category={lg.data.category}
          coverImage={lg.data.coverImage}
          href={`/reportagens/${lg.slug}`}
          date={lg.data.date}
          size="lg"
        />
      )}
      {md.map((article) => (
        <ArticleCard
          title={article.data.title}
          excerpt={article.data.excerpt}
          category={article.data.category}
          coverImage={article.data.coverImage}
          href={`/reportagens/${article.slug}`}
          date={article.data.date}
          size="md"
        />
      ))}
      {sm.map((article) => (
        <ArticleCard
          title={article.data.title}
          excerpt={article.data.excerpt}
          category={article.data.category}
          coverImage={article.data.coverImage}
          href={`/reportagens/${article.slug}`}
          date={article.data.date}
          size="sm"
        />
      ))}
    </div>
  </section>

  <!-- Copa Feminina Banner -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <CopaBanner />
  </div>

  <!-- Rádio UFSC Card -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <a
      href="/radio-ufsc"
      class="group block border border-nucleo-gold/30 bg-nucleo-black p-6 sm:p-8 card-hover"
    >
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <span class="text-nucleo-gold text-xs uppercase tracking-[0.2em]">Parceiro</span>
          <h3 class="mt-2 font-headline font-bold text-xl sm:text-2xl text-nucleo-white uppercase tracking-wide group-hover:text-nucleo-gold transition-colors duration-200">
            Rádio UFSC
          </h3>
          <p class="mt-2 text-sm text-nucleo-white/60 max-w-lg">
            50 anos no ar. Jornalismo, cultura e esporte no rádio universitário catarinense.
          </p>
        </div>
        <span class="inline-flex items-center gap-2 text-nucleo-gold text-sm uppercase tracking-wider whitespace-nowrap group-hover:gap-3 transition-all duration-200">
          Ouvir ao vivo
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </span>
      </div>
    </a>
  </section>

<!-- Modal Seleções -->
<div
  id="modal-overlay"
  class="fixed inset-0 z-[100] bg-black/85 hidden items-center justify-center p-4"
  onclick="closeModal(event)"
>
  <div
    id="modal-box"
    class="relative w-full max-w-lg bg-[#111] border border-nucleo-gold/30 overflow-hidden max-h-[90vh] overflow-y-auto"
  >
    <div id="modal-hero" class="relative h-[200px] bg-[#1a1a1a] flex items-end">
      <div class="absolute inset-0 flex items-center justify-center">
        <img id="modal-logo" src="" alt="" class="w-24 h-24 object-contain opacity-30" />
      </div>
      <div class="absolute inset-0 bg-gradient-to-t from-[#111] via-[#111]/60 to-transparent"></div>
      <div class="relative z-10 p-6">
        <span id="modal-grupo-tag" class="text-nucleo-gold text-[10px] tracking-[3px] uppercase mb-1 block"></span>
        <h3 id="modal-name" class="font-headline font-bold text-3xl text-nucleo-white uppercase"></h3>
      </div>
    </div>
    <button
      onclick="closeModalDirect()"
      class="absolute top-3 right-3 z-20 text-nucleo-gold hover:text-white transition-colors text-2xl leading-none w-8 h-8 flex items-center justify-center"
      aria-label="Fechar"
    >✕</button>
    <div class="p-6 space-y-4">
      <div class="grid grid-cols-2 gap-3">
        <div class="bg-white/5 p-3">
          <p class="text-nucleo-gold text-[9px] tracking-widest uppercase mb-1">Técnico</p>
          <p id="modal-tecnico" class="text-nucleo-white text-sm font-medium"></p>
        </div>
        <div class="bg-white/5 p-3">
          <p class="text-nucleo-gold text-[9px] tracking-widest uppercase mb-1">1ª Copa</p>
          <p id="modal-primeira" class="text-nucleo-white text-sm font-medium"></p>
        </div>
        <div class="bg-white/5 p-3">
          <p class="text-nucleo-gold text-[9px] tracking-widest uppercase mb-1">Melhor resultado</p>
          <p id="modal-melhor" class="text-nucleo-white text-sm font-medium"></p>
        </div>
        <div class="bg-white/5 p-3">
          <p class="text-nucleo-gold text-[9px] tracking-widest uppercase mb-1">Maior artilheiro</p>
          <p id="modal-artilheiro" class="text-nucleo-white text-sm font-medium"></p>
        </div>
      </div>
      <div class="bg-white/5 p-3">
        <p class="text-nucleo-gold text-[9px] tracking-widest uppercase mb-1">Eliminatórias</p>
        <p id="modal-elim" class="text-nucleo-white text-sm"></p>
      </div>
      <div class="bg-nucleo-gold/10 border border-nucleo-gold/20 p-3">
        <p class="text-nucleo-gold text-[9px] tracking-widest uppercase mb-1">Curiosidade</p>
        <p id="modal-curiosidade" class="text-nucleo-white/80 text-sm leading-relaxed"></p>
      </div>
      <div id="modal-conv-wrap" class="bg-white/5 p-3">
        <p class="text-nucleo-gold text-[9px] tracking-widest uppercase mb-1">Convocação</p>
        <p id="modal-convocacao" class="text-nucleo-white/70 text-xs leading-relaxed"></p>
      </div>
    </div>
  </div>
</div>

<script>
const selecoes = [
  { name: 'México', grupo: 'A', logo: 'mexico.png', tecnico: 'Javier Aguirre', primeira: '1930', melhor: 'Quartas de final (1970, 1986)', artilheiro: 'Javier Hernández (52 gols)', eliminatorias: 'V:— E:— D:— GM:— GS:—', curiosidade: 'O México será o primeiro país a sediar três edições da Copa (1970, 1986 e 2026).', convocacao: '' },
  { name: 'África do Sul', grupo: 'A', logo: 'africa.png', tecnico: 'Hugo Broos', primeira: '1998', melhor: 'Fase de grupos (2002)', artilheiro: 'Benni McCarthy (31 gols)', eliminatorias: 'V:5 E:3 D:2 GM:15 GS:9', curiosidade: 'Após o fim do apartheid em 1991, venceu a Copa das Nações Africanas em 1996.', convocacao: '' },
  { name: 'Coreia do Sul', grupo: 'A', logo: 'coreia-do-sul.png', tecnico: 'Hong Myung-bo', primeira: '1954', melhor: '4º lugar (2002)', artilheiro: 'Cha Bum-kun (58 gols)', eliminatorias: 'V:6 E:4 D:0 GM:20 GS:7', curiosidade: 'Primeira seleção asiática nas semifinais de uma Copa, em 2002.', convocacao: 'GR: Kim Seunggyu, Jo Hyeonwoo · DEF: Kim Min-jae, Park Jinseob, Lee Kihyuk · MEI: Lee Kang-in, Hwang Inbeom, Hwang Heechan · ATA: Son Heung-min, Oh Hyeongyu' },
  { name: 'Rep. Tcheca', grupo: 'A', logo: 'tcheca.png', tecnico: 'Miroslav Koubek', primeira: '2006', melhor: 'Vice-campeão 1934', artilheiro: 'Jan Koller (55 gols)', eliminatorias: 'V:5 E:1 D:2 GM:18 GS:8', curiosidade: 'Carrega a herança da Tchecoslováquia, vice-campeã em 1934 e 1962.', convocacao: '' },
  { name: 'Canadá', grupo: 'B', logo: 'canada.png', tecnico: 'Jesse Marsch', primeira: '1986', melhor: 'Fase de grupos (1986)', artilheiro: 'Jonathan David (39 gols)', eliminatorias: 'V:— E:— D:— GM:— GS:—', curiosidade: 'Alphonso Davies é o único jogador do Canadá a marcar gol em Copas.', convocacao: '' },
  { name: 'Bósnia', grupo: 'B', logo: 'bosnia.png', tecnico: 'Sergej Barbarez', primeira: '2014', melhor: 'Fase de grupos (2014)', artilheiro: 'Edin Džeko (73 gols)', eliminatorias: 'V:5 E:2 D:1 GM:17 GS:7', curiosidade: 'Classificou-se eliminando a Itália nos pênaltis por 4 a 1.', convocacao: 'GR: Nikola Vasilj · DEF: Kolasinac, Amar Dedic, Nikola Katic · MEI: Benjamin Tahirovic · ATA: Ermedin Demirovic, Edin Dzeko' },
  { name: 'Catar', grupo: 'B', logo: 'catar.png', tecnico: 'Julen Lopetegui', primeira: '2022', melhor: 'Fase de grupos (2022)', artilheiro: 'Almoez Ali (60 gols)', eliminatorias: 'V:6 E:2 D:0 GM:20 GS:4', curiosidade: 'Sediou a Copa de 2022, primeira no Oriente Médio.', convocacao: '' },
  { name: 'Suíça', grupo: 'B', logo: 'suica.png', tecnico: 'Murat Yakin', primeira: '1934', melhor: 'Quartas de final (1954)', artilheiro: 'Alexander Frei (42 gols)', eliminatorias: 'V:4 E:2 D:0 GM:14 GS:2', curiosidade: 'Em 2006, foi eliminada sem sofrer nenhum gol — perdeu nos pênaltis.', convocacao: 'GR: Gregor Kobel · DEF: Manuel Akanji, Nico Elvedi · MEI: Granit Xhaka, Remo Freuler, Ardon Jashari · ATA: Breel Embolo, Dan Ndoye' },
  { name: 'Brasil', grupo: 'C', logo: 'brasil.png', tecnico: 'Carlo Ancelotti', primeira: '1930', melhor: 'Campeão (5x)', artilheiro: 'Neymar (79 gols)', eliminatorias: 'V:8 E:4 D:6 GM:24 GS:17', curiosidade: 'Única seleção a participar de todas as edições da Copa do Mundo.', convocacao: 'GR: Alisson, Ederson · DEF: Bremer, Danilo, Gabriel Magalhães, Marquinhos · MEI: Bruno Guimarães, Casemiro, Lucas Paquetá · ATA: Endrick, Neymar, Raphinha, Vini Jr.' },
  { name: 'Marrocos', grupo: 'C', logo: 'marrocos.png', tecnico: 'Mohamed Ouahbi', primeira: '1970', melhor: '4º lugar (2022)', artilheiro: 'Ahmed Faras (36 gols)', eliminatorias: 'V:8 E:0 D:0 GM:22 GS:2', curiosidade: 'Primeira seleção africana a chegar às semifinais, em 2022.', convocacao: '' },
