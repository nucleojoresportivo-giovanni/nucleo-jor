---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CategoryBadge from '@/components/CategoryBadge.astro';
import { getCollection, render } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const reportagens = await getCollection('reportagens');
  return reportagens.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const formattedDate = entry.data.date.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.excerpt}
  ogImage={entry.data.coverImage}
>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14">
    <header class="mb-10">
      <CategoryBadge category={entry.data.category} />
      <h1 class="mt-4 font-headline font-bold text-3xl sm:text-4xl lg:text-5xl text-ixporte-white uppercase tracking-wide leading-tight">
        {entry.data.title}
      </h1>
      <p class="mt-4 font-editorial italic text-lg text-ixporte-white/70">
        {entry.data.excerpt}
      </p>
      <div class="mt-6 flex items-center gap-4 text-sm text-ixporte-white/50">
        <span>Por {entry.data.author}</span>
        <span aria-hidden="true">·</span>
        <time datetime={entry.data.date.toISOString()}>{formattedDate}</time>
      </div>
    </header>

    {entry.data.coverImage && (
      <figure class="mb-10">
        <img
          src={entry.data.coverImage}
          alt={entry.data.coverImageCaption ?? entry.data.title}
          class="w-full aspect-[16/9] object-cover"
          loading="eager"
        />
        {entry.data.coverImageCaption && (
          <figcaption class="mt-2 text-xs text-ixporte-white/40 text-center italic">
            {entry.data.coverImageCaption}
          </figcaption>
        )}
      </figure>
    )}

    <div class="prose prose-invert prose-lg max-w-none
      prose-headings:font-headline prose-headings:uppercase prose-headings:tracking-wide prose-headings:text-ixporte-white
      prose-p:text-ixporte-white/80 prose-p:leading-relaxed
      prose-a:text-ixporte-red prose-a:no-underline hover:prose-a:underline
      prose-blockquote:border-ixporte-red prose-blockquote:text-ixporte-white/70 prose-blockquote:font-editorial prose-blockquote:italic
      prose-strong:text-ixporte-white
      prose-li:text-ixporte-white/80">
      <Content />
    </div>

    <footer class="mt-12 pt-8 border-t border-white/10">
      <a href="/reportagens" class="text-ixporte-red hover:text-ixporte-white transition-colors duration-200 text-sm uppercase tracking-wider">
        ← Voltar para reportagens
      </a>
    </footer>
  </article>
</BaseLayout>

<style is:global>
  .prose h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .prose h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
  }
</style>
